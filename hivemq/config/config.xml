<?xml version="1.0"?>
<hivemq xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="config.xsd">

  <listeners>
    <tcp-listener>
      <port>1883</port>
      <bind-address>0.0.0.0</bind-address>
    </tcp-listener>

    <!-- TLS listener intentionally disabled for local/dev runtime readiness.
         Re-enable only when a valid PKCS12 keystore exists at /opt/hivemq/certs/hivemq.p12. -->
  </listeners>

  <mqtt>
    <session-expiry>
      <max-interval>3600</max-interval>
    </session-expiry>
    <message-expiry>
      <max-interval>300</max-interval>
    </message-expiry>
    <keep-alive>
      <max-keep-alive>60</max-keep-alive>
    </keep-alive>
    <quality-of-service>
      <max-qos>2</max-qos>
    </quality-of-service>
  </mqtt>

</hivemq>
