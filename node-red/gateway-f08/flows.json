    "id": "mqtt-in-tel-08",
    "type": "mqtt in",
    "z": "tab-floor08",
    "name": "A: telemetry",
    "topic": "campus/b01/f08/+/telemetry",
    "qos": "1",
    "datatype": "json",
    "broker": "broker-08",
    "nl": false,
    "rap": false,
    "inputs": 0,
    "x": 140,
    "y": 60,
