# Environment variables
LOG_LEVEL=INFO

# MQTT
MQTT_BROKER=localhost
MQTT_PORT=1883
# MQTT_USERNAME=
# MQTT_PASSWORD=
# MQTT_CLIENT_ID=campus-engine

# HiveMQ per-floor clients (Node-RED gateways) — matches hivemq/extensions/.../conf/credentials.xml
MQTT_USER_FLOOR01=floor01
MQTT_PASS_FLOOR01=floor01pass
MQTT_USER_FLOOR02=floor02
MQTT_PASS_FLOOR02=floor02pass
MQTT_USER_FLOOR03=floor03
MQTT_PASS_FLOOR03=floor03pass
MQTT_USER_FLOOR04=floor04
MQTT_PASS_FLOOR04=floor04pass
MQTT_USER_FLOOR05=floor05
MQTT_PASS_FLOOR05=floor05pass
MQTT_USER_FLOOR06=floor06
MQTT_PASS_FLOOR06=floor06pass
MQTT_USER_FLOOR07=floor07
MQTT_PASS_FLOOR07=floor07pass
MQTT_USER_FLOOR08=floor08
MQTT_PASS_FLOOR08=floor08pass
MQTT_USER_FLOOR09=floor09
MQTT_PASS_FLOOR09=floor09pass
MQTT_USER_FLOOR10=floor10
MQTT_PASS_FLOOR10=floor10pass
MQTT_USER_THINGSBOARD=thingsboard
MQTT_PASS_THINGSBOARD=tb_super_pass

# Simulation
PUBLISH_INTERVAL=5
TIME_ACCELERATION=1
STARTUP_JITTER=5

# Fleet
NUM_FLOORS=10
ROOMS_PER_FLOOR=20

# Outside environment
OUTSIDE_TEMP=30
OUTSIDE_TEMP_AMPLITUDE=5
OUTSIDE_HUMIDITY=60
OUTSIDE_HUMIDITY_AMPLITUDE=10

# Thermal model
THERMAL_ALPHA=0.01
THERMAL_BETA=0.5

# Persistence
SQLITE_SAVE_INTERVAL_SECONDS=30
# SQLITE_DB_PATH=data/campus_iot.db

# Fault simulation
FAULT_RATE=0.02
SENSOR_DRIFT_RATE=0.02
FROZEN_SENSOR_RATE=0.02
TELEMETRY_DELAY_RATE=0.02
NODE_DROPOUT_RATE=0.02
SENSOR_DRIFT_STEP_MAX=0.05
FROZEN_SENSOR_DURATION_SECONDS=30
TELEMETRY_DELAY_MIN_SECONDS=1
TELEMETRY_DELAY_MAX_SECONDS=3
NODE_DROPOUT_DURATION_SECONDS=30

# ----- Phase 2: HiveMQ / CoAP / Security -----
HIVEMQ_BROKER=hivemq
HIVEMQ_PORT=8883
HIVEMQ_PORT_PLAIN=1883
# MQTT over TLS to HiveMQ (requires hivemq/certs/ca.crt in container — see Step 9)
MQTT_USE_TLS=false
# HIVEMQ_CA_PATH=/app/hivemq/certs/ca.crt
COAP_BASE_PORT=5683
NUM_MQTT_ROOMS=100
NUM_COAP_ROOMS=100
COMMAND_QOS=2
ALERT_CON=true
# CoAP CON POST alerts to Node-RED gateway (requires POST /alerts listener on port)
COAP_ALERTS_ENABLED=false
COAP_ALERT_GATEWAY_PORT=5686
COAP_ALERT_GATEWAY_HOST_TEMPLATE=gateway-f{floor:02d}
COAP_ALERT_COOLDOWN_S=120
EDGE_THINNING_INTERVAL=60

# ----- Topic / URI naming convention (Phase 2) -----
# MQTT topic: campus/b01/f{floor:02d}/r{floor*100+room:03d}/{type}
#   types: telemetry | status | cmd | alert
# CoAP URI:  coap://sim-engine:{5683+offset}/f{floor:02d}/r{floor*100+room:03d}/telemetry
#   offset = (floor-1)*200 + (room-11)  → rooms 11-20 on floor 1 → ports 5683-5692
