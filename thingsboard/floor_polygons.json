{
  "legend": {
    "temperature_range_c": [18, 30],
    "color_function_js": "function tempToColor(t){const min=18,max=30;const x=Math.max(0,Math.min(1,(t-min)/(max-min)));const r=Math.round(255*x);const b=Math.round(255*(1-x));return `rgb(${r},80,${b})`;}"
  },
  "tooltip_template": {
    "title": "${room}",
    "lines": [
      "Temp: ${temperature} C",
      "Occupancy: ${occupancy}",
      "HVAC: ${hvac_mode}",
      "Last Seen: ${last_seen}"
    ]
  },
